{
  "name": "whether",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbo",
    "build": "node scripts/build.mjs",
    "build:cloudflare": "BUILD_TARGET=cloudflare node scripts/build.mjs",
    "build:cloudflare:skip-next-build": "BUILD_TARGET=cloudflare NEXT_ON_PAGES_SKIP_BUILD=1 node scripts/build.mjs",
    "build:pages": "bun run build:cloudflare",
    "build:pages:skip-next-build": "bun run build:cloudflare:skip-next-build",
    "start": "next start",
    "clean": "node scripts/clean-build-artifacts.mjs",
    "clean:build": "node scripts/clean-build-artifacts.mjs",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "check": "bun run review:hotspot-preflight && bun run lint && bun run typecheck && bun run test",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/run-tests.mjs",
    "test:watch": "node scripts/run-tests.mjs --watch",
    "time-machine:update-summaries": "node scripts/updateTimeMachineSummariesSince.mjs",
    "mcp:whether": "tsx scripts/mcp/whether-mcp-server.ts",
    "audit:cloudflare-warnings": "node scripts/cloudflare-warning-audit.mjs",
    "deploy:cloudflare": "node scripts/cloudflare-build-and-upload.mjs",
    "smoke:prod": "node scripts/prod-synthetic-smoke.mjs https://whether.work",
    "review:comment-trends": "node scripts/review-comment-trends.mjs --repo zz-plant/whether --limit 200",
    "review:comment-trends:update": "node scripts/review-comment-trends.mjs --repo zz-plant/whether --limit 200 --out docs/research/review-comment-trends.latest.json --summary-out docs/research/review-comment-trends.latest.md",
    "review:hotspot-preflight": "node scripts/review-hotspot-preflight.mjs",
    "summary-archive:migrate-structured": "bunx tsx scripts/migrateSummaryArchiveStructured.ts --write",
    "summary-archive:check-structured": "bunx tsx scripts/migrateSummaryArchiveStructured.ts",
    "brief:weekly:artifact": "bunx tsx scripts/generateWeeklySlackBrief.ts --out artifacts/weekly-slack-brief.txt"
  },
  "engines": {
    "node": "20.16.x"
  },
  "packageManager": "bun@1.3.9",
  "dependencies": {
    "@base-ui/react": "1.2.0",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "simple-icons": "^16.10.0",
    "web-haptics": "^0.0.6",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "1.13.16",
    "@modelcontextprotocol/sdk": "1.27.1",
    "@types/node": "24.4.0",
    "@types/react": "19.2.14",
    "autoprefixer": "10.4.24",
    "eslint": "9.38.0",
    "eslint-config-next": "16.1.6",
    "postcss": "8.5.6",
    "tailwindcss": "3.4.17",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  }
}
