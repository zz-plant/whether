{
  "name": "whether",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbo",
    "build": "node scripts/build.mjs",
    "build:pages": "BUILD_TARGET=pages node scripts/build.mjs",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "check": "bun run lint && bun run typecheck && bun run test",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/run-tests.mjs",
    "test:watch": "node scripts/run-tests.mjs --watch",
    "mcp:whether": "tsx scripts/mcp/whether-mcp-server.ts"
  },
  "engines": {
    "node": ">=20.16.0"
  },
  "packageManager": "bun@1.3.9",
  "dependencies": {
    "@base-ui/react": "1.2.0",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "1.13.16",
    "@modelcontextprotocol/sdk": "1.27.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "24.4.0",
    "@types/react": "19.2.14",
    "autoprefixer": "10.4.24",
    "eslint": "9.38.0",
    "eslint-config-next": "16.1.6",
    "postcss": "8.5.6",
    "tailwindcss": "3.4.17",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  }
}
